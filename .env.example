# Local Docker Compose host ports
NGINX_PORT=8080
USER_SERVICE_PORT=3001
QUESTION_SERVICE_PORT=3002
MATCHING_SERVICE_PORT=3003
COLLAB_SERVICE_PORT=3004

# Shared backend infrastructure for Docker Compose.
# Internal hosts should use Docker service names on the peerprep-network.
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_service_key_here
REDIS_USERNAME=your_redis_username
REDIS_PASSWORD=your_redis_password
REDIS_HOST=your_redis_host
REDIS_PORT=your_redis_port
RABBITMQ_URL=amqp://user:root@rabbitmq:5672

# Collaboration service runtime overrides for local development
FRONTEND_ORIGIN=http://localhost:5173
PUBLIC_WS_URL=http://localhost:3004
GRACE_PERIOD_MS=30000
JOIN_TOKEN_TTL_MS=300000
RABBITMQ_MATCH_FOUND_EXCHANGE=peerprep
RABBITMQ_MATCH_FOUND_QUEUE=collaboration.match-found
RABBITMQ_MATCH_FOUND_ROUTING_KEY=match.found

# Shared app defaults
LOG_LEVEL=info
