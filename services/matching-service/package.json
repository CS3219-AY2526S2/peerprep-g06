{
  "name": "matching-service",
  "version": "1.0.0",
  "description": "Matching service for PeerPrep",
  "main": "dist/index.js",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "amqplib": "^0.10.9",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "redis": "^5.10.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@testcontainers/redis": "^11.14.0",
    "@types/amqplib": "^0.10.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.2",
    "@vitest/coverage-v8": "^4.1.4",
    "nodemon": "^3.1.11",
    "socket.io-client": "^4.8.3",
    "testcontainers": "^11.14.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
